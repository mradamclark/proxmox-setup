# Rendered by the deploy task into /docker/traefik/.env at deploy time.
# Any `{{ foo }}` is resolved against the usual Ansible vars + vault.

# Cloudflare API token scoped to Zone:DNS:Edit on your zone.
# Stored in vault_cloudflare_dns_token (group_vars/all/vault.yml).
CF_DNS_API_TOKEN={{ vault_cloudflare_dns_token }}
